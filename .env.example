APP_MODE=mock
APP_NAME=stock-wave-assistant
DATABASE_PATH=./data/app.db
CACHE_DIR=./data/cache
REPORT_DIR=./data/reports

MARKET_PROVIDER=mock
# Set MARKET_PROVIDER=akshare only after installing the optional AkShare extra
# and filling stock symbols in config/watchlist.yaml.
LLM_PROVIDER=codex_cli
CODEX_CLI_PATH=
CODEX_MODEL=gpt-5.5
CODEX_TIMEOUT_SECONDS=120
CODEX_SANDBOX_MODE=read-only
ENABLE_CODEX_CLI=false
